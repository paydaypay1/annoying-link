modules = ["web", "nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5173

[workflows]
runButton = "Dev"

[[workflows.workflow]]
name = "Dev"
mode = "sequential"
author = 58938564

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Migrate Dev"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx prisma generate client"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Vite Build"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Local"

[[workflows.workflow]]
name = "Local"
mode = "sequential"
author = 58938564

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx index.js"

[[workflows.workflow]]
name = "Migrate Dev"
mode = "sequential"
author = 58938564

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx prisma migrate dev"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx prisma generate client"

[[workflows.workflow]]
name = "Vite Build"
mode = "sequential"
author = 58938564

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "tsc"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "vite build"

[[workflows.workflow]]
name = "Install"
mode = "sequential"
author = 58938564

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install @fontsource/roboto @mui/icons-material"

[[workflows.workflow]]
name = "Build For Deployment"
mode = "sequential"
author = 58938564

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"
